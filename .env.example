# ========================
# CẤU HÌNH FACEBOOK
# ========================

# Cookie Facebook của bạn (lấy từ browser)
# Hướng dẫn: F12 → Application → Cookies → facebook.com → copy toàn bộ
FB_COOKIES=

# Hoặc dùng file cookies (xuất từ browser extension "Get cookies.txt")
FB_COOKIES_FILE=cookies.txt

# User-Agent của browser bạn (F12 → Network → bất kỳ request → copy User-Agent)
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# ========================
# CẤU HÌNH DOWNLOAD
# ========================

# Thư mục lưu video
OUTPUT_DIR=downloads

# Chất lượng video: best / worst / 720 / 1080
VIDEO_QUALITY=best

# Số luồng tải song song
MAX_WORKERS=3

# Giới hạn số video tải mỗi lần chạy (0 = không giới hạn)
MAX_DOWNLOADS=0
